# ── Kununu target ───────────────────────────────────────────────
KUNUNU_NAME=Test GmbH
KUNUNU_URL=https://www.kununu.com/de/test/kommentare
KUNUNU_BASE_URL=https://www.kununu.com

# ── Discord ─────────────────────────────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXX/YYYY
# Optional: Discord user ID to ping. Leave empty to disable.
DISCORD_USER_ID=
# Embed colors (hex). New posts vs. edited reviews.
EMBED_COLOR_NEW=0x00b4d8
EMBED_COLOR_UPDATE=0xf9a826

# ── Behaviour ───────────────────────────────────────────────────
# Where the lowdb JSON file lives (kept on a Docker volume).
DB_PATH=./data/db.json
CHECK_INTERVAL_MS=300000   # 5 minutes
RETRY_MS=60000             # 1 minute after an error
# Max time to wait for the page (incl. WAF challenge + JS render)
PAGE_TIMEOUT_MS=45000
